# === v1 (site) ===
# Gerçek alan adı bağlanınca doğru canonical/OG/sitemap için:
# NEXT_PUBLIC_SITE_URL=https://www.akucarnakliyat.com

# === v2 (panel) — Faz 2 ===
# PostgreSQL (mevcut DB; şema akucarnakliyat). schema parametresi şemayı hedefler.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=akucarnakliyat"

# JWT imzalama anahtarı (uzun, rastgele). Örn: openssl rand -base64 48
JWT_SECRET="change-me-long-random-secret"

# İlk admin (seed). Seed sonrası şifre panelden değiştirilebilir.
SEED_ADMIN_EMAIL="admin@akucarnakliyat.com"
SEED_ADMIN_PASSWORD="change-me-strong-password"

# Cloudinary (medya yükleme — 2.x)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
